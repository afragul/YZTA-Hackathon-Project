# Auto-detect text files and normalize line endings to LF in the repo.
# Working tree line endings are decided per-pattern below.
* text=auto eol=lf

# --- Source code (always LF, even on Windows checkouts) -----------------
*.py        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.zsh       text eol=lf
*.fish      text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.env       text eol=lf
.env*       text eol=lf

# Files without an extension that are typically scripts / configs
Dockerfile          text eol=lf
Dockerfile.*        text eol=lf
.dockerignore       text eol=lf
.gitignore          text eol=lf
.gitattributes      text eol=lf
.editorconfig       text eol=lf
Makefile            text eol=lf
*.mako              text eol=lf

# --- Windows-only scripts (must keep CRLF) ------------------------------
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# --- Binary assets (no EOL conversion, no diff noise) -------------------
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.svg       text eol=lf
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.tar       binary
*.7z        binary
*.bz2       binary
*.xz        binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.mp3       binary
*.mp4       binary
*.webm      binary
*.mov       binary
*.wasm      binary
