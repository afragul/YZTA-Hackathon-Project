POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon_pass
POSTGRES_DB=hackathon_db

SECRET_KEY=change_me_to_a_long_random_string_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

PROJECT_NAME=Hackathon API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

MINIO_ROOT_USER=kobai_minio
MINIO_ROOT_PASSWORD=kobai_minio_pass
MINIO_BUCKET=kobai-uploads
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

FIRST_ADMIN_USERNAME=yzta-admin
FIRST_ADMIN_EMAIL=admin@yzta.dev
FIRST_ADMIN_PASSWORD=Yzta123!

FIRST_USER_USERNAME=yzta-user
FIRST_USER_EMAIL=user@yzta.dev
FIRST_USER_PASSWORD=Yzta123!

# WhatsApp Cloud API
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_DEFAULT_API_VERSION=v21.0
# Optional: 32-byte url-safe base64 Fernet key. Leave empty to derive from SECRET_KEY.
WHATSAPP_ENCRYPTION_KEY=
WHATSAPP_PUBLIC_WEBHOOK_BASE=http://localhost:8000

# AI Providers (LangChain backend)
AI_DEFAULT_PROVIDER=google
AI_DEFAULT_MODEL=gemini-2.5-flash
AI_DEFAULT_MAX_TOKENS=2048
GOOGLE_GENAI_BASE_URL=https://generativelanguage.googleapis.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
